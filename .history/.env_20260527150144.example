# Configuração da API de Relatórios

# URL da API para geração de relatórios psicossociais
# Em desenvolvimento: http://localhost:5000
# Em produção: seu domínio/API (ex: https://api.seu-dominio.com)
VITE_RELATORIO_API_URL=http://localhost:5000

# Porta padrão do servidor local (desenvolvimento)
VITE_API_PORT=5000

# Domínio da aplicação (para CORS)
VITE_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
